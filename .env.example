# ──────────────────────────────────────────────
#  SIGplatform — Environment Variables Template
#  Copy this file to .env and fill in all values
#  NEVER commit .env to version control
# ──────────────────────────────────────────────

# Django
SECRET_KEY=change-this-to-a-long-random-string-at-least-50-chars
DEBUG=False
DJANGO_ENV=production

# Hosts allowed to reach the app (comma-separated, no spaces)
# Include the server IP / domain where this will run
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,your-domain.com

# ── Databases ────────────────────────────────

# Main DB  (sig_dailylogs)
DB_NAME=sig_dailylogs
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=3306

# SigTools DB  (sigtools_beta — can be the same host as main)
SIGTOOLS_DB_NAME=sigtools_beta
SIGTOOLS_DB_USER=your_db_user
SIGTOOLS_DB_PASSWORD=your_db_password
SIGTOOLS_DB_HOST=your_db_host
SIGTOOLS_DB_PORT=3306

# Inventory DB  (typically a local/LAN MySQL instance)
INVENTORY_DB_NAME=Daily
INVENTORY_DB_USER=your_db_user
INVENTORY_DB_PASSWORD=your_db_password
INVENTORY_DB_HOST=192.168.x.x
INVENTORY_DB_PORT=3306

# Schedules DB  (same host as Inventory usually)
SCHEDULES_DB_NAME=slc_schedules
SCHEDULES_DB_USER=your_db_user
SCHEDULES_DB_PASSWORD=your_db_password
SCHEDULES_DB_HOST=192.168.x.x
SCHEDULES_DB_PORT=3306

# ── SQLAlchemy URLs (used by codegen / schema inspector) ──────
# Format: mysql+pymysql://user:password@host:port/dbname
SQLALCHEMY_DATABASE_URL=mysql+pymysql://your_db_user:your_db_password@your_db_host:3306/sig_dailylogs
SIGTOOLS_SQLALCHEMY_URL=mysql+pymysql://your_db_user:your_db_password@your_db_host:3306/sigtools_beta

# ── Codegen / Ollama ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# Absolute path inside the container where app code lives (do not change unless you move it)
BASE_APPS_DIR=/app/apps
CODEGEN_BACKUP_DIR=/app/codegen_backups

# ── Docker ───────────────────────────────────
# Must match the container_name of the web service in docker-compose.yml
DOCKER_CONTAINER_NAME=SIGplatform-web

# ── JWT ──────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS / CSRF ──────────────────────────────
# Comma-separated list of origins allowed to make CORS requests
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# Comma-separated list of origins trusted for CSRF
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# ── Redis ────────────────────────────────────
# The docker-compose.yml sets this automatically using the service name "redis".
# Override only if using an external Redis instance (outside Docker Compose).
# REDIS_URL=redis://your-external-redis-host:6379/0

# ── Anthropic (Claude API) ───────────────────
# Required for the chatbot feature
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── Microsoft Graph Mail ─────────────────────
# Required for email notifications (approval requests, onboarding, etc.)
# Register an app in Azure AD with Mail.Send permission
MS_GRAPH_TENANT_ID=your-azure-tenant-id
MS_GRAPH_CLIENT_ID=your-azure-app-client-id
MS_GRAPH_CLIENT_SECRET=your-azure-app-client-secret
MS_GRAPH_SENDER=noreply@your-domain.com
